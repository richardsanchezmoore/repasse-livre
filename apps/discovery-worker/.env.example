SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Token (Bearer) do fipe.online (https://fipe.online/) — opcional, mas
# recomendado: o domínio publico sem chave (fipe.parallelum.com.br) tem
# limite de taxa proprio e pode ser bloqueado sob volume.
FIPE_API_KEY=

# URL da categoria/região da OLX a ser varrida nesta execução. O worker
# aplica sozinho o filtro nativo "Ofertas abaixo da FIPE" (resolvendo a
# chave de query string direto da página, não fixada aqui) — reduz o
# universo de anúncios de ~24.000 para ~800 no RS (medido em 19/06/2026).
OLX_CATEGORY_URL=https://www.olx.com.br/autos-e-pecas/carros-vans-e-utilitarios/estado-rs

# Margem mínima (%) abaixo da FIPE para uma oportunidade ser elegível
MARGEM_MINIMA_PERCENTUAL=5

# "inicial": varre paginando até atingir JANELA_INICIAL_DIAS (usar uma vez,
#   para popular a prateleira antes do primeiro envio).
# "incremental": varre paginando até encontrar o primeiro anúncio já salvo
#   no banco (uso recorrente, ex: a cada 6h via cron).
MODO_VARREDURA=incremental

# Janela (em dias) usada apenas no modo "inicial"
JANELA_INICIAL_DIAS=30

# Limite de páginas por execução, como proteção contra varredura infinita
MAX_PAGINAS=50
