# Domínio público do site, usado pra montar links (ex: página individual de
# oportunidade, compartilhamento). Sem essa env var cai no fallback
# https://repasselivre.com — só precisa setar em ambientes diferentes (local,
# preview).
NEXT_PUBLIC_SITE_URL=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Mesma URL acima + a anon/public key (painel Supabase → Project Settings →
# API) — usadas pelo Supabase Auth (login/cadastro), tanto no navegador
# quanto no server. Diferente da service role key: respeita RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Liga o botão "Continuar com Facebook" no login/cadastro. Fica DESLIGADO
# (vazio/ausente) até o app do Meta poder ser publicado — o que exige Business
# Verification com CNPJ. Quando o CNPJ sair e o app for publicado, setar "true"
# aqui (e no Vercel) e redeployar. Ver lib/flags.ts.
NEXT_PUBLIC_FACEBOOK_LOGIN_ENABLED=

# Token (Bearer) do fipe.online (https://fipe.online/) — sem ele, a consulta
# de marca/modelo/ano/valor no formulário /enviar usa o domínio público
# (fipe.parallelum.com.br) sem chave, que tem limite de taxa baixo e falha
# sob qualquer volume de uso (429 "limite de taxa excedido").
FIPE_API_KEY=

# Chave da API da Anthropic (Claude) — liga a PROSA do parecer do Copiloto de
# Compra (Fase C): a LLM reescreve o parecer determinístico em prosa natural de
# especialista, sem inventar número. SEM essa chave, o Copiloto mantém o parecer
# determinístico (template) — a página nunca quebra. Setar no Vercel pra ativar
# em produção. Ver lib/bia/parecerLLM.ts.
ANTHROPIC_API_KEY=
